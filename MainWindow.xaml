<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="acorn.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:acorn"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Acorn Backup">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="AppNav"
                    PaneTitle="Acorn"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    PaneDisplayMode="Left"
                    Loaded="AppNav_Loaded"
                    SelectionChanged="AppNav_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="StatusNavItem" Tag="Status" Content="Status">
                <NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Nav/status.png" ShowAsMonochrome="False" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="BackupSettingsNavItem" Tag="BackupSettings" Content="Backup Settings">
                <NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Nav/backups.png" ShowAsMonochrome="False" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem x:Name="SettingsNavItem" Tag="Settings" Content="Settings">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
