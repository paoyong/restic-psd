<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="acorn.Pages.BackupsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="36,28,36,36" Spacing="20" MaxWidth="800">

            <!-- ── Page header ── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Backups" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="ConfigPathText"
                               Opacity="0.5"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Margin="0,2,0,0" />
                </StackPanel>
                <ToggleSwitch x:Name="MasterToggle"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              OnContent="Enabled"
                              OffContent="Disabled"
                              Toggled="MasterToggle_Toggled" />
            </Grid>

            <!-- ── Save feedback ── -->
            <InfoBar x:Name="SaveBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Success"
                     Title="Settings saved"
                     Message="Config written and scheduled tasks updated." />

            <!-- ── Watched Folders ── -->
            <StackPanel Spacing="8">
                <TextBlock Text="Watched Folders"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Acorn monitors these folders for matching files."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.6" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <ListView x:Name="FoldersList"
                                  SelectionMode="Single"
                                  MaxHeight="180"
                                  MinHeight="48">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Add Folder" Click="AddFolder_Click" />
                            <Button Content="Remove Selected" Click="RemoveFolder_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── Include Patterns ── -->
            <StackPanel Spacing="8">
                <TextBlock Text="Include Patterns (Keywords)"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Only files whose names match at least one pattern are backed up. Wildcards supported (e.g. *WORKING*)."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.6"
                           TextWrapping="Wrap" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <ListView x:Name="IncludeList"
                                  SelectionMode="Single"
                                  MaxHeight="140"
                                  MinHeight="48">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewIncludeBox"
                                     PlaceholderText="e.g. *WORKING*"
                                     KeyDown="NewIncludeBox_KeyDown" />
                            <Button Grid.Column="1" Content="Add" Click="AddInclude_Click" />
                            <Button Grid.Column="2" Content="Remove Selected" Click="RemoveInclude_Click" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── Backups Scheduled ── -->
            <StackPanel Spacing="8">
                <TextBlock Text="Backups Scheduled"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Each entry creates its own restic repository and Task Scheduler task. Interval is in hours (e.g. 0.5 = every 30 min, 24 = every 24 hours)."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.6"
                           TextWrapping="Wrap" />

                <!-- Dynamically populated in code-behind -->
                <StackPanel x:Name="SchedulesPanel" Spacing="8" />

                <Button Content="Add New Backup" Click="AddNewBackup_Click" />
            </StackPanel>

            <!-- ── Apply / Save ── -->
            <Button Content="Apply and Save"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right"
                    Click="Apply_Click" />

        </StackPanel>
    </ScrollViewer>
</Page>
